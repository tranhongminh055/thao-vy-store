rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow read to everyone, restrict write to authenticated users for testing.
    match /product-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null; // <-- change to request.auth.token.admin == true after testing
    }
    match /payment_proofs/{allPaths=**} {
      allow read: if true;
      allow write: if true; // Allow anyone (including guests) to upload payment proofs
    }
  }
}
