        <!-- INFO BOX -->
        <mxCell id="info_box" value="Key Points:&#10;- Collections are top-level containers&#10;- Documents have unique IDs&#10;- Subcollections are nested under parent documents&#10;- Denormalization: copy product data to orders for fast queries&#10;- No joins in Firestore - data must be duplicated&#10;- Keep documents under 1 MB&#10;- Use arrays carefully (max 20000 items)&#10;- Index frequently queried fields" style="rounded=1;whiteSpace=wrap;html=1;fontSize=9;align=left;fillColor=#f5f5f5;strokeColor=#666;padding=10;" vertex="1" parent="1">
